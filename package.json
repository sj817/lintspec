{
  "name": "lintspec",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "pnpm build && pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "publint": "pnpm --filter \"./packages/*\" exec publint",
    "docs:dev": "pnpm --filter lintspec-docs docs:dev",
    "docs:build": "pnpm --filter lintspec-docs docs:build"
  },
  "devDependencies": {
    "@qwqo/eslint-config": "workspace:*",
    "@qwqo/prettier-config": "workspace:*",
    "eslint": "10.4.1",
    "prettier": "3.8.4",
    "publint": "0.3.14"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
